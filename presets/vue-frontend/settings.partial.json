{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit",
        "pattern": "*.vue",
        "hooks": [{
          "type": "command",
          "command": "npx vue-tsc --noEmit 2>&1 | tail -5",
          "statusMessage": "Checking Vue types..."
        }]
      },
      {
        "matcher": "Edit",
        "pattern": "*.ts",
        "hooks": [{
          "type": "command",
          "command": "npx vue-tsc --noEmit 2>&1 | tail -5",
          "statusMessage": "Typechecking..."
        }]
      }
    ]
  }
}
