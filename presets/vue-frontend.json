{
    "stackName": "Vue 3 Frontend (TypeScript)",
    "detect": {
      "files": ["vite.config.ts", "tsconfig.json"],
      "packageDeps": ["vue"]
    },
    "claudeMd": {
      "buildCommands": {
        "frontend": {
          "install": "pnpm install",
          "dev": "pnpm dev",
          "build": "pnpm build",
          "test": "pnpm test",
          "typecheck": "pnpm type-check",
          "lint": "pnpm lint"
        }
      }
    },
    "postToolUseHooks": [
      {
        "matcher": "Edit",
        "pattern": "*.vue",
        "hooks": [{
          "type": "command",
          "command": "npx vue-tsc --noEmit 2>&1 | head -30",
          "statusMessage": "Checking Vue types..."
        }]
      },
      {
        "matcher": "Edit",
        "pattern": "*.ts",
        "hooks": [{
          "type": "command",
          "command": "npx vue-tsc --noEmit 2>&1 | head -30",
          "statusMessage": "Typechecking..."
        }]
      },
      {
        "matcher": "Edit",
        "pattern": "*.tsx",
        "hooks": [{
          "type": "command",
          "command": "npx vue-tsc --noEmit 2>&1 | head -30",
          "statusMessage": "Typechecking..."
        }]
      }
    ]
  }